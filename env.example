# ─────────────────────────────────────────────
# Forms Overlay — Variables d'environnement
# Copier en .env et remplir les valeurs
# ─────────────────────────────────────────────

# ── Docs (upstream) ──────────────────────────
DOCS_API_URL=http://localhost:8071/api/v1.0
DOCS_FRONTEND_URL=http://localhost:3000

# ── Forms Backend ─────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://forms:forms@db:5432/forms
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Dev bypass OIDC (laisser vide en production)
# Active uniquement si DEBUG=True
DEV_BYPASS_TOKEN=dev-bypass-token

# ── Forms Frontend ────────────────────────────
NEXT_PUBLIC_DOCS_API_URL=http://localhost:8071/api/v1.0
NEXT_PUBLIC_DOCS_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_FORMS_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Dev bypass OIDC (mettre à "false" en production)
NEXT_PUBLIC_DEV_MODE=true
NEXT_PUBLIC_DEV_BYPASS_TOKEN=dev-bypass-token

# ── PostgreSQL ────────────────────────────────
POSTGRES_DB=forms
POSTGRES_USER=forms
POSTGRES_PASSWORD=forms
